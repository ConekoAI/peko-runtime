{
    "name": "identity_tool",
    "description": "Echo back injected identity parameters (for testing context injection)",
    "parameters": {
        "type": "object",
        "properties": {
            "message": {
                "type": "string",
                "description": "Optional message to echo back"
            }
        }
    },
    "reserved_parameters": {
        "session_id": {
            "source": "runtime",
            "field": "session_id",
            "description": "Current session ID"
        },
        "agent_id": {
            "source": "runtime",
            "field": "agent_id",
            "description": "Current agent ID"
        },
        "run_id": {
            "source": "runtime",
            "field": "run_id",
            "description": "Current run ID"
        },
        "workspace": {
            "source": "runtime",
            "field": "workspace",
            "description": "Workspace directory path"
        }
    }
}
