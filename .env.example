# Pekobot Environment Configuration
# Copy this file to .env and fill in your API keys

# =============================================================================
# LLM PROVIDERS (choose one or more)
# =============================================================================

# OpenAI
OPENAI_API_KEY=sk-...

# Anthropic  
ANTHROPIC_API_KEY=sk-ant-...

# Kimi (Moonshot)
KIMI_API_KEY=sk-...

# Kimi Code (coding endpoint)
KIMI_CODE_API_KEY=sk-...

# OpenRouter (access 100+ models)
OPENROUTER_API_KEY=sk-or-...

# Groq
GROQ_API_KEY=gsk_...

# Together AI
TOGETHER_API_KEY=...

# Fireworks
FIREWORKS_API_KEY=...

# Venice
VENICE_API_KEY=...

# Cohere
COHERE_API_KEY=...

# Perplexity
PERPLEXITY_API_KEY=pplx-...

# xAI
XAI_API_KEY=...

# AWS Bedrock (requires AWS credentials)
AWS_ACCESS_KEY_ID=...
AWS_SECRET_ACCESS_KEY=...
AWS_REGION=us-east-1

# Ollama (local, no API key needed)
# OLLAMA_HOST=http://localhost:11434

# =============================================================================
# COMMUNICATION CHANNELS
# =============================================================================

# WhatsApp Business API
WHATSAPP_ACCESS_TOKEN=...
WHATSAPP_PHONE_NUMBER_ID=...
WHATSAPP_VERIFY_TOKEN=...
# WHATSAPP_ALLOWED_NUMBERS=+1234567890,+0987654321  # Optional: restrict to specific numbers

# Telegram Bot API
TELEGRAM_BOT_TOKEN=...

# Discord Bot Token
DISCORD_BOT_TOKEN=...
# DISCORD_ALLOWED_USERS=user1,user2  # Optional: restrict to specific users

# Slack
SLACK_BOT_TOKEN=xoxb-...
SLACK_APP_TOKEN=xapp-...

# Matrix
MATRIX_HOMESERVER=https://matrix.org
MATRIX_USER_ID=@bot:matrix.org
MATRIX_ACCESS_TOKEN=...

# =============================================================================
# CONEKO NETWORK (optional)
# =============================================================================

CONEKO_ENDPOINT=https://api.coneko.ai
CONEKO_TOKEN=...

# =============================================================================
# ADVANCED OPTIONS
# =============================================================================

# Calendar Integration (Google Calendar / Outlook)
CALENDAR_PROVIDER=google
CALENDAR_CLIENT_ID=your_client_id_here
CALENDAR_CLIENT_SECRET=your_client_secret_here
CALENDAR_ACCESS_TOKEN=your_access_token_here
CALENDAR_REFRESH_TOKEN=your_refresh_token_here
